<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/ ..\FrameXML\UI.xsd">
	<Frame name="LootGuardMainFrame" parent="UIParent" hidden="true" enableMouse="true" movable="true" frameStrata="DIALOG">
		<Size x="720" y="480"/>
		<Anchors>
			<Anchor point="CENTER"/>
		</Anchors>
		<Scripts>
			<OnLoad>
				LootGuardMainFrame_OnLoad(self)
			</OnLoad>
			<OnHide>
				LootGuardMainFrame_OnHide(self)
			</OnHide>
		</Scripts>
		<Frames>
			<Button name="$parentClose" inherits="UIPanelCloseButton">
				<Anchors>
					<Anchor point="TOPRIGHT" x="-4" y="-4"/>
				</Anchors>
			</Button>
			<Frame name="$parentTabBar">
				<Size x="700" y="32"/>
				<Anchors>
					<Anchor point="TOPLEFT" x="10" y="-36"/>
				</Anchors>
			</Frame>
			<Frame name="$parentContent">
				<Size x="700" y="400"/>
				<Anchors>
					<Anchor point="TOPLEFT" x="10" y="-72"/>
				</Anchors>
				<Frames>
					<ScrollFrame name="$parentSessionScroll" inherits="UIPanelScrollFrameTemplate" hidden="false">
						<Anchors>
							<Anchor point="TOPLEFT"/>
							<Anchor point="BOTTOMRIGHT"/>
						</Anchors>
						<ScrollChild>
							<Frame name="$parentSessionChild">
								<Size x="660" y="400"/>
							</Frame>
						</ScrollChild>
					</ScrollFrame>
					<ScrollFrame name="$parentNinjaScroll" inherits="UIPanelScrollFrameTemplate" hidden="true">
						<Anchors>
							<Anchor point="TOPLEFT"/>
							<Anchor point="BOTTOMRIGHT"/>
						</Anchors>
						<ScrollChild>
							<Frame name="$parentNinjaChild">
								<Size x="660" y="400"/>
							</Frame>
						</ScrollChild>
					</ScrollFrame>
					<Frame name="$parentSettings" hidden="true">
						<Anchors>
							<Anchor point="TOPLEFT"/>
							<Anchor point="BOTTOMRIGHT"/>
						</Anchors>
					</Frame>
				</Frames>
			</Frame>
		</Frames>
		<Layers>
			<Layer level="ARTWORK">
				<FontString name="$parentTitle" inherits="GameFontNormalLarge" text="LootGuard">
					<Anchors>
						<Anchor point="TOPLEFT" x="16" y="-12"/>
					</Anchors>
				</FontString>
			</Layer>
		</Layers>
	</Frame>
</Ui>
